APP_NAME="CIRT Payroll"
APP_ORGANIZATION_NAME="CIRT"
DEFAULT_COMPANY_CODE="CIRT"
DISABLE_PUBLIC_SIGNUP=true

# Legacy alias — ignored when DISABLE_PUBLIC_SIGNUP is set.
# ALLOW_PUBLIC_SIGNUP=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=public

# React dev server (comma-separated for multiple origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# Set true only when intentionally archiving unused HRMS module tables (see 2026_05_28_110000 migration).
# CIRT_ARCHIVE_UNUSED_TABLES=false
GOOGLE_CLIENT_ID=
